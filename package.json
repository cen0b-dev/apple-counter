{
  "name": "apple-balance",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "esbuild \"app.jsx\" --bundle --format=esm --sourcemap --outfile=\"dist/app.js\" --servedir=. --watch",
    "build": "esbuild \"app.jsx\" --bundle --format=esm --minify --outfile=\"dist/app.js\"",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0"
  }
}
